# Ninja Translate — environment configuration
#
# Copy this file to `.env` and fill in real values. The app reads from
# process.env so any secret manager that injects env vars works too
# (Doppler, 1Password CLI, Infisical, AWS SSM, etc.).
#
# Required for the bot to start: GEMINI_API_KEY.
# Required for production CF Access gate: CF_ACCESS_TEAM_DOMAIN + CF_ACCESS_AUD.

# ─── Required ────────────────────────────────────────────────────────────────

# Google AI Studio key (https://aistudio.google.com/app/apikey).
GEMINI_API_KEY=your-google-ai-studio-key

# ─── WhatsApp ────────────────────────────────────────────────────────────────

# Captured automatically the first time you run `pnpm login` and pair via QR.
# After pairing, copy the printed value here so the bot starts cleanly on boot.
BOT_JID=

# ─── Translator ──────────────────────────────────────────────────────────────

# Override the model if needed. Default is fine for most users.
GEMINI_MODEL=gemini-2.5-flash

# Enable the ElevenLabs + Anthropic fallback path for low-resource languages
# (Burmese specifically). Off by default. Both keys below required when on.
TRANSLATOR_FALLBACK=false
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=

# ─── Admin API ───────────────────────────────────────────────────────────────

# Where the admin Hono server binds. Keep on loopback in production and
# expose only via Cloudflare Tunnel (or your reverse proxy of choice).
ADMIN_HOST=127.0.0.1
ADMIN_PORT=7878

# Comma-separated list of origins allowed to call the API (CORS).
# In production, set this to your dashboard's public URL.
API_ALLOWED_ORIGINS=https://translate.your-domain.com

# ─── Cloudflare Access (production gate) ─────────────────────────────────────

# Your team domain, e.g. "your-team.cloudflareaccess.com".
# When unset, the JWT middleware is bypassed entirely (local-dev path).
CF_ACCESS_TEAM_DOMAIN=
# AUD tag from the CF Access app for the API origin.
CF_ACCESS_AUD=

# ─── Storage paths (optional overrides) ──────────────────────────────────────

# Defaults to ~/.ninja-translate/. Set NINJA_HOME to relocate the whole tree,
# or override the individual paths below.
# NINJA_HOME=/var/lib/ninja-translate
# DB_PATH=/var/lib/ninja-translate/data.db
# AUDIO_DIR=/var/lib/ninja-translate/audio
# SESSION_DIR=/var/lib/ninja-translate/wa-session

# ─── Backups (optional) ──────────────────────────────────────────────────────

# Cloudflare R2 (S3-compatible). Required only if you run `pnpm backup`.
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Alerts (optional) ───────────────────────────────────────────────────────

# Telegram bot for fatal-error alerts. Both required to enable.
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=
