{
  "name": "ninja-translate",
  "version": "0.1.0",
  "description": "WhatsApp bot that translates voice notes and @mentioned text across N languages per group, powered by Gemini.",
  "license": "MIT",
  "author": "Sean Katz",
  "homepage": "https://github.com/SeanZoR/ninja-translate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanZoR/ninja-translate.git"
  },
  "bugs": {
    "url": "https://github.com/SeanZoR/ninja-translate/issues"
  },
  "keywords": [
    "whatsapp",
    "translation",
    "bot",
    "gemini",
    "baileys",
    "voice-translation",
    "i18n",
    "multilingual",
    "hono",
    "sqlite"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:admin": "NINJA_ADMIN_ONLY=1 tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "login": "tsx scripts/login.ts",
    "backup": "tsx scripts/backup.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "video:render": "cd remotion && npm install --silent && npm run render && mkdir -p ../web/assets/videos && cp out/how-to.mp4 ../web/assets/videos/how-to.mp4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.682.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.0",
    "jose": "^5.9.6",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@whiskeysockets/baileys",
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
